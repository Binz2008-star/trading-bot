    "trading_strategies": {
      "default_strategy": "smart_scalping",
      "strategies": {
        "smart_scalping": {
          "enabled": true,
          "timeframe": "5m",
          "indicators": ["RSI", "EMA", "MACD", "Bollinger_Bands"],
          "entry_conditions": {
            "rsi_oversold": 30,
            "rsi_overbought": 70,
            "ema_crossover": true,
            "macd_signal": true
          },
          "exit_conditions": {
            "profit_target": 2.0,
            "stop_loss": 1.0,
            "time_limit_minutes": 30
          }
        }
      }
    },
    "technical_indicators": {
      "rsi": {
        "period": 14,
        "oversold": 30,
        "overbought": 70
      },
      "ema": {
        "fast_period": 12,
        "slow_period": 26,
        "signal_period": 9
      },
      "macd": {
        "fast_period": 12,
        "slow_period": 26,
        "signal_period": 9
      },
      "bollinger_bands": {
        "period": 20,
        "std_dev": 2
      },
      "stochastic": {
        "k_period": 14,
        "d_period": 3,
        "oversold": 20,
        "overbought": 80
      },
      "adx": {
        "period": 14,
        "trend_strength": 25
      }
    },
    "auto_trading": {
      "enabled": true,
      "mode": "conservative",
      "scan_interval_seconds": 30,
      "max_concurrent_trades": 3,
      "position_sizing": "fixed_percent",
      "position_size_percent": 1.0,
      "enable_compound_growth": true,
      "rebalance_frequency": "daily"
    },
    "sniper_mode": {
      "enabled": true,
      "scan_interval_seconds": 5,
      "volatility_threshold": 2.0,
      "volume_spike_threshold": 3.0,
      "price_change_threshold": 1.0,
      "max_positions": 2,
      "hold_time_minutes": 15
    },
    "notifications": {
      "telegram": {
        "enabled": false,
        "notify_on_trade": true,
        "notify_on_profit": true,
        "notify_on_loss": true,
        "notify_on_error": true,
        "daily_summary": true
      },
      "email": {
        "enabled": false,
        "notify_on_trade": false,
        "notify_on_profit": true,
        "notify_on_loss": true,
        "notify_on_error": true,
        "weekly_summary": true
      }
    },
    "ai_features": {
      "sentiment_analysis": {
        "enabled": false,
        "sources": ["twitter", "reddit", "news"],
        "weight": 0.2
      },
      "price_prediction": {
        "enabled": false,
        "model": "lstm",
        "prediction_horizon_hours": 4,
        "confidence_threshold": 0.7
      },
      "pattern_recognition": {
        "enabled": true,
        "patterns": ["head_and_shoulders", "double_top", "triangle", "flag"],
        "min_confidence": 0.8
      }
